{
  "name": "@ceriousdevtech/react-cerious-scroll",
  "version": "1.0.3",
  "description": "React bindings for CeriousScroll — high-performance virtual scrolling with O(1) memory and no height estimation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "author": "Cerious DevTech LLC <info@ceriousdevtech.com>",
  "homepage": "https://github.com/ceriousdevtech/react-cerious-scroll#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ceriousdevtech/react-cerious-scroll.git"
  },
  "bugs": {
    "url": "https://github.com/ceriousdevtech/react-cerious-scroll/issues",
    "email": "info@ceriousdevtech.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "virtual-scroll",
    "virtual-scrolling",
    "infinite-scroll",
    "performance",
    "large-lists",
    "data-grid",
    "variable-height",
    "o1-memory",
    "cerious-scroll"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts"
  },
  "dependencies": {
    "@ceriousdevtech/cerious-scroll": "^1.0.4"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "react-window": "^1.8.10",
    "@types/react-window": "^1.8.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  }
}
